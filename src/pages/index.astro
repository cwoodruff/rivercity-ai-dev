<!-- ═══════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════ -->
<style>
  /* ── NAV ────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    transition: background 0.3s;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 68px;
  }
  .nav-logo img { height: 40px; width: auto; }
  .nav-links {
    display: flex;
    gap: 0.25rem;
    margin-left: auto;
  }
  .nav-links a {
    padding: 0.4rem 0.8rem;
    font-family: 'Syne', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-links a:hover { color: var(--electric-blue); background: rgba(30,156,255,0.08); }
  .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
  .nav-cta { padding: 0.55rem 1.2rem; font-size: 0.85rem; }
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: 0.2s;
  }
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem 1.25rem;
    border-top: 1px solid var(--border);
    gap: 0.25rem;
  }
  .nav-mobile a {
    padding: 0.5rem 0;
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  .nav-mobile a:last-child { border-bottom: none; }

  @media (max-width: 820px) {
    .nav-links, .nav-cta { display: none; }
    .nav-hamburger { display: flex; }
    .nav-mobile.open { display: flex; }
    .nav-actions { margin-left: auto; }
  }

  /* ── HERO ───────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 0 5rem;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 40%, transparent 100%);
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .orb-blue {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(30,156,255,0.22) 0%, transparent 70%);
    top: -100px; left: -200px;
    animation: drift 14s ease-in-out infinite alternate;
  }
  .orb-teal {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(13,148,136,0.18) 0%, transparent 70%);
    bottom: -50px; right: -100px;
    animation: drift 18s ease-in-out infinite alternate-reverse;
  }
  .orb-amber {
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(245,158,11,0.16) 0%, transparent 70%);
    top: 30%; right: 15%;
    animation: drift 22s ease-in-out infinite alternate;
  }

  @keyframes drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(40px, 30px) scale(1.08); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(13,148,136,0.35);
    background: rgba(13,148,136,0.08);
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--deep-teal);
    margin-bottom: 1.5rem;
  }
  .badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--deep-teal);
    box-shadow: 0 0 8px var(--deep-teal);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(0.8); }
  }

  .hero-logo { margin-bottom: 1.5rem; width: 100%; max-width: 800px; }
  .hero-logo img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(30,156,255,0.25));
    transition: transform 0.4s ease;
  }
  .hero-logo img:hover { transform: scale(1.04); }

  .hero-title {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 800;
    margin-bottom: 1.25rem;
    max-width: 800px;
  }
  .gradient-text {
    background: linear-gradient(135deg, var(--electric-blue), var(--deep-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .accent-text { color: var(--amber); }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-muted);
    max-width: 620px;
    margin-bottom: 2rem;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.25rem 2.5rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--surface);
    backdrop-filter: blur(8px);
  }
  .stat { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--electric-blue);
    line-height: 1;
  }
  .stat-plus { font-size: 1rem; }
  .stat-label { font-size: 0.75rem; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; }
  .stat-divider { width: 1px; height: 36px; background: var(--border); }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    opacity: 0.6;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--electric-blue), transparent);
    animation: scroll-drop 1.8s ease-in-out infinite;
  }
  @keyframes scroll-drop {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ── SECTIONS ───────────────────────────────── */
  .section { padding: 6rem 0; }
  .section--alt { background: var(--bg2); }
  .section-header {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  }

  /* ── ABOUT ──────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .about-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }
  .about-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .about-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.1rem; }
  .about-list strong {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
    color: var(--text);
  }
  .about-list p { font-size: 0.9rem; color: var(--text-muted); }

  .about-card-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }
  .about-card {
    padding: 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: var(--card-shadow);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .about-card:hover { transform: translateX(6px); }
  .about-card--1 { border-left: 3px solid var(--electric-blue); }
  .about-card--2 { border-left: 3px solid var(--deep-teal); margin-left: 1.5rem; }
  .about-card--3 { border-left: 3px solid var(--amber); }
  .about-card-icon { font-size: 1.6rem; margin-bottom: 0.5rem; }
  .about-card h4 { font-family: 'Syne', sans-serif; font-size: 1rem; margin-bottom: 0.4rem; }
  .about-card p { font-size: 0.875rem; color: var(--text-muted); }

  /* ── TOPICS ─────────────────────────────────── */
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .topic-card {
    padding: 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: var(--card-shadow);
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
    cursor: default;
  }
  .topic-card:hover { transform: translateY(-4px); }
  .topic-card--blue:hover  { border-color: var(--electric-blue); box-shadow: 0 8px 32px rgba(30,156,255,0.15); }
  .topic-card--teal:hover  { border-color: var(--deep-teal);     box-shadow: 0 8px 32px rgba(13,148,136,0.15); }
  .topic-card--amber:hover { border-color: var(--amber);         box-shadow: 0 8px 32px rgba(245,158,11,0.15); }
  .topic-card--orange:hover{ border-color: var(--neon-orange);   box-shadow: 0 8px 32px rgba(251,146,60,0.15); }
  .topic-icon { font-size: 1.8rem; display: block; margin-bottom: 0.75rem; }
  .topic-card h3 { font-family: 'Syne', sans-serif; font-size: 1rem; margin-bottom: 0.5rem; }
  .topic-card p  { font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; }

  /* ── EVENTS ─────────────────────────────────── */
  .events-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .events-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .event-card--featured {
    padding: 2rem;
    border-radius: 18px;
    border: 1px solid rgba(30,156,255,0.3);
    background: var(--surface);
    box-shadow: var(--glow-blue), var(--card-shadow);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .event-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    background: linear-gradient(135deg, var(--electric-blue), var(--electric-blue-dim));
    color: #fff;
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    width: fit-content;
  }
  .event-date {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .event-month {
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--electric-blue);
    text-transform: uppercase;
  }
  .event-day {
    font-family: 'Syne', sans-serif;
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    color: var(--text);
  }
  .event-info h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--text);
  }
  .event-info p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.65; }
  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .event-side { display: flex; flex-direction: column; gap: 1rem; }
  .event-mini {
    padding: 1.25rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    transition: border-color 0.2s, transform 0.2s;
  }
  .event-mini:hover { border-color: var(--deep-teal); transform: translateX(4px); }
  .event-mini-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 44px;
    padding: 0.5rem;
    border-radius: 8px;
    background: var(--bg2);
  }
  .event-mini-date span { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--deep-teal); }
  .event-mini-date strong { font-family: 'Syne', sans-serif; font-size: 1.4rem; font-weight: 800; line-height: 1; color: var(--text); }
  .event-mini-info h4 { font-family: 'Syne', sans-serif; font-size: 0.9rem; margin-bottom: 0.35rem; }
  .event-mini-meta { display: flex; gap: 0.5rem; align-items: center; font-size: 0.8rem; color: var(--text-faint); flex-wrap: wrap; }
  .event-type {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-family: 'Syne', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .event-type--past     { background: rgba(13,148,136,0.12); color: var(--deep-teal); }
  .event-type--upcoming { background: rgba(30,156,255,0.12); color: var(--electric-blue); }

  /* ── COMMUNITY ──────────────────────────────── */
  .community-stats {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    margin-bottom: 3.5rem;
    padding: 2rem;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: var(--card-shadow);
  }
  .community-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }
  .community-stat-icon { font-size: 1.5rem; }
  .community-stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--electric-blue);
    line-height: 1;
  }
  .community-stat-label { font-size: 0.72rem; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; }

  .personas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .persona-card {
    padding: 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--surface);
    transition: transform 0.25s, border-color 0.25s;
  }
  .persona-card:hover { transform: translateY(-4px); border-color: var(--amber); }
  .persona-emoji { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
  .persona-card h4 { font-family: 'Syne', sans-serif; font-size: 0.95rem; margin-bottom: 0.4rem; }
  .persona-card p  { font-size: 0.85rem; color: var(--text-muted); }

  /* ── RESOURCES ──────────────────────────────── */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .resource-card {
    padding: 1.75rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
    text-decoration: none;
  }
  .resource-card:hover { transform: translateY(-4px); }
  .resource-card--blue:hover  { border-color: var(--electric-blue); box-shadow: 0 8px 32px rgba(30,156,255,0.12); }
  .resource-card--teal:hover  { border-color: var(--deep-teal);     box-shadow: 0 8px 32px rgba(13,148,136,0.12); }
  .resource-card--amber:hover { border-color: var(--amber);         box-shadow: 0 8px 32px rgba(245,158,11,0.12); }
  .resource-card--orange:hover{ border-color: var(--neon-orange);   box-shadow: 0 8px 32px rgba(251,146,60,0.12); }
  .resource-icon { font-size: 1.8rem; }
  .resource-card h3 { font-family: 'Syne', sans-serif; font-size: 1rem; color: var(--text); }
  .resource-card p  { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; flex: 1; }
  .resource-cta {
    font-family: 'Syne', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--electric-blue);
    margin-top: 0.5rem;
  }
  .resource-card--teal  .resource-cta { color: var(--deep-teal); }
  .resource-card--amber .resource-cta { color: var(--amber); }
  .resource-card--orange .resource-cta { color: var(--neon-orange); }

  /* ── NEWSLETTER ─────────────────────────────── */
  .newsletter-section {
    position: relative;
    padding: 6rem 0;
    overflow: hidden;
  }
  .newsletter-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .newsletter-box {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
