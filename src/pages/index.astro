---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- ═══════════════════════════════════════════════
     NAV
════════════════════════════════════════════════ -->
<nav class="nav">
  <div class="container nav-inner">
    <a href="#hero" class="nav-logo">
      <img src="/logo-dark.png"  alt="River City AI & Dev User Group" class="logo-dark"  />
      <img src="/logo-light.png" alt="River City AI & Dev User Group" class="logo-light" />
    </a>
    <div class="nav-links">
      <a href="#about">About</a>
      <a href="#topics">Topics</a>
      <a href="#events">Events</a>
      <a href="#community">Community</a>
      <a href="#resources">Resources</a>
    </div>
    <div class="nav-actions">
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <span class="icon-sun">☀️</span>
        <span class="icon-moon">🌙</span>
      </button>
      <a href="#newsletter" class="btn btn-primary nav-cta">Join the Group</a>
    </div>
    <button class="nav-hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <!-- Mobile menu -->
  <div class="nav-mobile" id="mobile-menu">
    <a href="#about">About</a>
    <a href="#topics">Topics</a>
    <a href="#events">Events</a>
    <a href="#community">Community</a>
    <a href="#resources">Resources</a>
    <a href="#newsletter" class="btn btn-primary" style="margin-top:0.5rem;">Join the Group</a>
  </div>
</nav>


<!-- ═══════════════════════════════════════════════
     HERO
════════════════════════════════════════════════ -->
<section class="hero" id="hero">
  <!-- Animated grid background -->
  <div class="hero-grid" aria-hidden="true"></div>
  <!-- Gradient orbs -->
  <div class="orb orb-blue" aria-hidden="true"></div>
  <div class="orb orb-teal" aria-hidden="true"></div>
  <div class="orb orb-amber" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-badge reveal">
      <span class="badge-dot"></span>
      Grand Rapids, Michigan
    </div>

    <div class="hero-logo reveal" style="transition-delay:0.1s">
      <img src="/logo-dark.png"  alt="River City AI & Dev User Group Logo" class="logo-dark"  />
      <img src="/logo-light.png" alt="River City AI & Dev User Group Logo" class="logo-light" />
    </div>

    <h1 class="hero-title reveal" style="transition-delay:0.2s">
      Where <span class="gradient-text">Grand Rapids</span><br />
      Developers <span class="accent-text">Build Together</span>
    </h1>

    <p class="hero-sub reveal" style="transition-delay:0.3s">
      A community for AI engineers, web and mobile developers, Rustaceans, .NET devs,
      and open-source contributors — every skill level, every stack. Monthly meetups,
      real talks, real people.
    </p>

    <div class="hero-actions reveal" style="transition-delay:0.4s">
      <a href="#newsletter" class="btn btn-primary">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Join the Group
      </a>
      <a href="#events" class="btn btn-secondary">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Upcoming Events
      </a>
    </div>

    <div class="hero-stats reveal" style="transition-delay:0.5s">
      <div class="stat">
        <span class="stat-num">200<span class="stat-plus">+</span></span>
        <span class="stat-label">Members</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">Monthly</span>
        <span class="stat-label">Meetups</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">Free</span>
        <span class="stat-label">Always</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     ABOUT
════════════════════════════════════════════════ -->
<section class="section" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <span class="section-label reveal">About Us</span>
        <h2 class="section-title reveal" style="transition-delay:0.1s">
          Built by devs,<br />for devs.
        </h2>
        <p class="section-subtitle reveal" style="transition-delay:0.15s">
          River City AI & Dev User Group is Grand Rapids' home for curious, hands-on technologists. 
          Whether you're shipping your first app or your tenth production AI system — 
          you belong here.
        </p>
        <ul class="about-list reveal" style="transition-delay:0.2s">
          <li>
            <span class="about-icon">🤝</span>
            <div>
              <strong>Inclusive by design</strong>
              <p>Beginners, seniors, career changers — all welcome. No gatekeeping, ever.</p>
            </div>
          </li>
          <li>
            <span class="about-icon">⚡</span>
            <div>
              <strong>Practical & forward-looking</strong>
              <p>Real demos, live coding, honest takes on AI tools and dev trends.</p>
            </div>
          </li>
          <li>
            <span class="about-icon">🌊</span>
            <div>
              <strong>Rooted in Grand Rapids</strong>
              <p>Local talent, local companies, local opportunities. West Michigan's tech scene is thriving.</p>
            </div>
          </li>
        </ul>
        <div class="reveal" style="transition-delay:0.25s">
          <a href="#newsletter" class="btn btn-accent" style="margin-top:1.5rem;">Get Involved →</a>
        </div>
      </div>
      <div class="about-visual reveal" style="transition-delay:0.15s">
        <div class="about-card-stack">
          <div class="about-card about-card--1">
            <div class="about-card-icon">🧠</div>
            <h4>AI & Machine Learning</h4>
            <p>LLMs, agents, fine-tuning, RAG pipelines, and responsible AI deployment.</p>
          </div>
          <div class="about-card about-card--2">
            <div class="about-card-icon">🛠️</div>
            <h4>Hands-On Demos</h4>
            <p>Every meetup features live coding, tool walkthroughs, and Q&amp;A sessions.</p>
          </div>
          <div class="about-card about-card--3">
            <div class="about-card-icon">🌐</div>
            <h4>Cross-Stack Community</h4>
            <p>Web, mobile, systems, cloud — we talk it all without the tribal nonsense.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     TOPICS
════════════════════════════════════════════════ -->
<section class="section section--alt" id="topics">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">What We Cover</span>
      <h2 class="section-title">Every stack,<br />every discipline.</h2>
      <p class="section-subtitle">
        Our talks and workshops span the full spectrum of modern software development 
        — you don't have to be an "AI person" to fit in.
      </p>
    </div>

    <div class="topics-grid">
      {[
        { icon: '🤖', title: 'AI & LLMs', desc: 'ChatGPT, Claude, Gemini, local models, prompt engineering, agents, RAG, and AI-native app development.', color: 'blue' },
        { icon: '🕸️', title: 'Web Development', desc: 'React, Astro, Next.js, SvelteKit, Tailwind, edge functions, and the ever-evolving frontend landscape.', color: 'teal' },
        { icon: '📱', title: 'Mobile Dev', desc: 'Swift, Kotlin, Flutter, React Native, Expo — cross-platform strategies and native best practices.', color: 'amber' },
        { icon: '🦀', title: 'Rust', desc: 'Systems programming, WebAssembly, async Rust, Axum, memory safety, and the joys of the borrow checker.', color: 'orange' },
        { icon: '🔷', title: '.NET & C#', desc: 'ASP.NET Core, Blazor, MAUI, Minimal APIs, EF Core, and Microsoft Azure integrations.', color: 'blue' },
        { icon: '🌍', title: 'Open Source', desc: "Contributing to OSS, running your own projects, licenses, community governance, and why it matters.", color: 'teal' },
        { icon: '☁️', title: 'Cloud & DevOps', desc: 'Kubernetes, Docker, CI/CD, AWS, Azure, GCP, infrastructure as code, and platform engineering.', color: 'amber' },
        { icon: '🔐', title: 'Security & Privacy', desc: 'AppSec, threat modeling, OAuth, zero-trust architectures, and keeping user data safe.', color: 'orange' },
        { icon: '📊', title: 'Data Engineering', desc: 'Pipelines, vector databases, analytics, dbt, DuckDB, and making sense of big datasets.', color: 'blue' },
      ].map((t, i) => (
        <div class={`topic-card topic-card--${t.color} reveal`} style={`transition-delay:${i * 0.06}s`}>
          <span class="topic-icon">{t.icon}</span>
          <h3>{t.title}</h3>
          <p>{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     EVENTS
════════════════════════════════════════════════ -->
<section class="section" id="events">
  <div class="container">
    <div class="events-header">
      <div class="reveal">
        <span class="section-label">Events</span>
        <h2 class="section-title">Mark your calendar.</h2>
        <p class="section-subtitle">Monthly meetups, workshops, and special events throughout West Michigan.</p>
      </div>
      <a href="https://www.meetup.com" target="_blank" rel="noopener noreferrer" class="btn btn-secondary reveal" style="align-self:flex-end">
        All Events on Meetup →
      </a>
    </div>

    <div class="events-grid">
      <!-- Featured event -->
      <div class="event-card event-card--featured reveal">
        <div class="event-badge">Next Up</div>
        <div class="event-date">
          <span class="event-month">APR</span>
          <span class="event-day">15</span>
        </div>
        <div class="event-info">
          <h3>Building Agentic AI Apps with Claude & LangGraph</h3>
          <p>Dive deep into multi-step AI agents. We'll build a real-world workflow automation tool live, then open the floor for discussion on where agents actually work — and where they fall flat.</p>
          <div class="event-meta">
            <span>📍 Grand Rapids, MI (TBA)</span>
            <span>🕕 6:00 PM – 8:30 PM</span>
            <span>🆓 Free to attend</span>
          </div>
          <a href="https://www.meetup.com" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="margin-top:1.25rem;">RSVP on Meetup</a>
        </div>
      </div>

      <!-- Past / upcoming -->
      <div class="event-side">
        {[
          { month: 'MAR', day: '18', title: 'Rust for AI: Candle & Burn Frameworks', type: 'Past', note: 'Slides available' },
          { month: 'FEB', day: '20', title: 'Full-Stack AI with Next.js 14 & Vercel AI SDK', type: 'Past', note: '48 attendees' },
          { month: 'MAY', day: '20', title: 'Open Source LLMs — Llama 3, Mistral & Self-Hosting', type: 'Upcoming', note: 'RSVP opening soon' },
        ].map((e, i) => (
          <div class={`event-mini reveal`} style={`transition-delay:${(i+1)*0.1}s`}>
            <div class="event-mini-date">
              <span>{e.month}</span>
              <strong>{e.day}</strong>
            </div>
            <div class="event-mini-info">
              <h4>{e.title}</h4>
              <div class="event-mini-meta">
                <span class={`event-type event-type--${e.type.toLowerCase()}`}>{e.type}</span>
                <span>{e.note}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     COMMUNITY
════════════════════════════════════════════════ -->
<section class="section section--alt" id="community">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Our Community</span>
      <h2 class="section-title">Real people.<br />Real conversations.</h2>
      <p class="section-subtitle">
        We're a group of practitioners, experimenters, and learners. No hype merchants, no vendor pitches — 
        just honest builders who care about the craft.
      </p>
    </div>

    <div class="community-stats reveal" style="transition-delay:0.15s">
      {[
        { num: '200+', label: 'Members', icon: '👥' },
        { num: '2+', label: 'Years Active', icon: '🗓️' },
        { num: '24+', label: 'Meetups Held', icon: '🎤' },
        { num: '15+', label: 'Speaker Talks', icon: '💡' },
        { num: '∞', label: 'Side Projects', icon: '🚀' },
        { num: 'GR', label: 'Grand Rapids', icon: '🌊' },
      ].map(s => (
        <div class="community-stat">
          <span class="community-stat-icon">{s.icon}</span>
          <span class="community-stat-num">{s.num}</span>
          <span class="community-stat-label">{s.label}</span>
        </div>
      ))}
    </div>

    <div class="personas-grid">
      {[
        { emoji: '🎓', role: 'Students & Bootcamp Grads', desc: 'Breaking into tech and building their first real projects.' },
        { emoji: '🏢', role: 'Senior Engineers', desc: 'Sharing hard-won knowledge and exploring what\'s next.' },
        { emoji: '🔬', role: 'AI Researchers', desc: 'Turning papers into practice and theory into tools.' },
        { emoji: '🧑‍💼', role: 'Tech Leads & CTOs', desc: 'Staying current and finding the right talent.' },
        { emoji: '🔄', role: 'Career Switchers', desc: 'Pivoting into tech from other fields and finding their footing.' },
        { emoji: '🛠️', role: 'Indie Makers', desc: 'Shipping side projects and hunting for collaborators.' },
      ].map((p, i) => (
        <div class={`persona-card reveal`} style={`transition-delay:${i*0.07}s`}>
          <span class="persona-emoji">{p.emoji}</span>
          <h4>{p.role}</h4>
          <p>{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     RESOURCES
════════════════════════════════════════════════ -->
<section class="section" id="resources">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Resources</span>
      <h2 class="section-title">Stay connected &<br />keep learning.</h2>
      <p class="section-subtitle">
        Links to our channels, past talks, and recommended tools for group members.
      </p>
    </div>

    <div class="resources-grid">
      {[
        {
          icon: '💬',
          title: 'Discord Server',
          desc: 'Our main community hub. Share links, ask questions, find project collaborators, and chat between meetups.',
          cta: 'Join Discord',
          href: '#newsletter',
          color: 'blue',
        },
        {
          icon: '📹',
          title: 'Past Talks',
          desc: 'Recordings and slide decks from previous meetups. Catch up on sessions you missed or revisit the good ones.',
          cta: 'Watch Recordings',
          href: '#newsletter',
          color: 'teal',
        },
        {
          icon: '📰',
          title: 'Newsletter',
          desc: 'Monthly digest: upcoming events, curated AI & dev articles, job leads, and member project spotlights.',
          cta: 'Subscribe',
          href: '#newsletter',
          color: 'amber',
        },
        {
          icon: '🐙',
          title: 'GitHub Organization',
          desc: 'Code samples, demo repos, and open-source projects from our members and meetup sessions.',
          cta: 'View on GitHub',
          href: '#newsletter',
          color: 'orange',
        },
        {
          icon: '🗺️',
          title: 'Meetup.com',
          desc: 'RSVP for upcoming events, browse past meetups, and keep your schedule synced.',
          cta: 'Follow on Meetup',
          href: 'https://www.meetup.com',
          color: 'blue',
        },
        {
          icon: '🔗',
          title: 'LinkedIn Group',
          desc: 'Professional networking, job postings, and company news from our member community.',
          cta: 'Connect on LinkedIn',
          href: '#newsletter',
          color: 'teal',
        },
      ].map((r, i) => (
        <a href={r.href} class={`resource-card resource-card--${r.color} reveal`} style={`transition-delay:${i*0.07}s`} target={r.href.startsWith('http') ? '_blank' : '_self'} rel="noopener noreferrer">
          <span class="resource-icon">{r.icon}</span>
          <h3>{r.title}</h3>
          <p>{r.desc}</p>
          <span class="resource-cta">{r.cta} →</span>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     NEWSLETTER / SIGNUP
════════════════════════════════════════════════ -->
<section class="section newsletter-section" id="newsletter">
  <div class="newsletter-bg" aria-hidden="true">
    <div class="orb orb-blue" style="opacity:0.5"></div>
    <div class="orb orb-teal" style="opacity:0.4; left:60%; top:30%"></div>
  </div>
  <div class="container">
    <div class="newsletter-box reveal">
      <div class="newsletter-text">
        <span class="section-label">Stay In The Loop</span>
        <h2 class="section-title" style="color:var(--text)">
          Join River City<br /><span class="gradient-text">AI & Dev</span>
        </h2>
        <p>
          Sign up to get notified about upcoming meetups, workshops, and community news. 
          We send one digest per month — no spam, ever.
        </p>
        <ul class="newsletter-perks">
          <li>✅ Monthly event announcements</li>
          <li>✅ AI & dev digest with curated reads</li>
          <li>✅ Member project spotlights</li>
          <li>✅ Job board & collaboration opportunities</li>
          <li>✅ Exclusive Discord invite</li>
        </ul>
      </div>
      <div class="newsletter-form-wrap">
        <form class="signup-form" id="signup-form" novalidate>
          <div class="form-field">
            <label for="signup-name">Your Name</label>
            <input type="text" id="signup-name" name="name" placeholder="Jane Smith" autocomplete="name" required />
          </div>
          <div class="form-field">
            <label for="signup-email">Email Address</label>
            <input type="email" id="signup-email" name="email" placeholder="jane@example.com" autocomplete="email" required />
          </div>
          <div class="form-field">
            <label for="signup-role">Your Primary Role <span class="optional">(optional)</span></label>
            <select id="signup-role" name="role">
              <option value="">Select one…</option>
              <option>AI / ML Engineer</option>
              <option>Web Developer</option>
              <option>Mobile Developer</option>
              <option>Backend / Systems Engineer</option>
              <option>DevOps / Platform Engineer</option>
              <option>Data Engineer / Analyst</option>
              <option>Student / Bootcamp Grad</option>
              <option>Tech Lead / Manager</option>
              <option>Founder / Indie Maker</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-field">
            <label>Interests <span class="optional">(pick any)</span></label>
            <div class="checkbox-grid">
              {['AI & LLMs', 'Web Dev', 'Mobile Dev', 'Rust', '.NET / C#', 'Open Source', 'Cloud & DevOps', 'Data Engineering'].map(tag => (
                <label class="check-label">
                  <input type="checkbox" name="interests" value={tag} />
                  <span>{tag}</span>
                </label>
              ))}
            </div>
          </div>
          <button type="submit" class="btn btn-accent signup-btn">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
            Join the Group
          </button>
          <p class="form-note">Free forever · No spam · Unsubscribe anytime</p>
        </form>
        <div class="signup-success" id="signup-success" style="display:none">
          <div class="success-icon">🎉</div>
          <h3>You're in!</h3>
          <p>Welcome to River City AI & Dev. Keep an eye on your inbox — our next event announcement is coming soon. See you at the meetup! 🌊</p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     FOOTER
════════════════════════════════════════════════ -->
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src="/logo-dark.png"  alt="River City AI & Dev" class="footer-logo logo-dark"  />
      <img src="/logo-light.png" alt="River City AI & Dev" class="footer-logo logo-light" />
      <p>Grand Rapids, Michigan's community for developers, AI builders, and curious technologists.</p>
      <div class="footer-socials">
        <a href="#" aria-label="Discord" class="social-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
        </a>
        <a href="#" aria-label="GitHub" class="social-btn">
